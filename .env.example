# Static interview forecasts (Babuganj 44mm / Rangpur 10mm). Prefer live weather.
DEMO_FORECAST_ENABLED=false
LIVE_WEATHER_ENABLED=true
LIVE_WEATHER_API_URL=https://api.open-meteo.com/v1/forecast
LIVE_WEATHER_TIMEOUT=5

GPT_BACKUP_ENABLED=true
LLM_MODEL=gpt-4o-mini
WHISPER_MODEL=gpt-4o-mini-transcribe

TTS_PROVIDER=edge
TTS_VOICE=bn-BD-PradeepNeural

PUBLIC_BASE_URL=http://localhost:9603
TELEPHONY_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
