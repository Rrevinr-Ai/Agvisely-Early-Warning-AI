# Copy to /opt/agvisely/.env on the VPS and fill in real values.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=service_agent

OPENAI_API_KEY=sk-your-key
AGVISELY_API_URL=https://your-agvisely-api
AGVISELY_API_KEY=your_key
AGVISELY_TIMEOUT=3

GPT_BACKUP_ENABLED=true
LLM_MODEL=gpt-4o-mini
WHISPER_MODEL=gpt-4o-mini-transcribe

TTS_PROVIDER=edge
TTS_VOICE=bn-BD-PradeepNeural

# Public URL of the API (use your VPS IP or domain)
PUBLIC_BASE_URL=http://YOUR_VPS_IP:9603

TELEPHONY_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional overrides (defaults match this GitHub repo)
# BACKEND_IMAGE=ghcr.io/rrevinr-ai/agvisely-early-warning-ai-backend:latest
# FRONTEND_IMAGE=ghcr.io/rrevinr-ai/agvisely-early-warning-ai-frontend:latest
